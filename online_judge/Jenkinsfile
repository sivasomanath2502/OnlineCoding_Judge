pipeline {
    agent any

    tools {
        maven 'Maven 3'
        jdk 'JDK 17'
    }

    environment {
        DOCKERHUB_USERNAME = 'sivasomanath2502'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Check Docker') {
            steps {
                sh 'docker --version'
            }
        }

        stage('Checkout') {
            steps {
                echo 'Checking out source code...'
                checkout scm
            }
        }

        stage('Build') {
            steps {
                echo 'Building all services...'
                dir('online_judge') {
                    sh 'mvn -B clean package -DskipTests'
                }
            }
        }

        stage('Unit Tests') {
             steps {
                 echo 'Skipping tests (not implemented yet)'
             }
         }

        stage('Docker Build') {
            steps {
                dir('online_judge') {
                    sh """
                        docker build -t ${DOCKERHUB_USERNAME}/submission-service:${IMAGE_TAG} ./submission-service
                        docker build -t ${DOCKERHUB_USERNAME}/worker-service:${IMAGE_TAG} ./worker-service
                        docker build -t ${DOCKERHUB_USERNAME}/result-service:${IMAGE_TAG} ./result-service
                        docker build -t ${DOCKERHUB_USERNAME}/api-gateway:${IMAGE_TAG} ./api-gateway
                    """
                }
            }
        }

        stage('Docker Push') {
            steps {
                echo 'Logging into DockerHub...'

                withCredentials([usernamePassword(
                    credentialsId: 'dockerhub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin

                        docker push ${DOCKERHUB_USERNAME}/submission-service:${IMAGE_TAG}
                        docker push ${DOCKERHUB_USERNAME}/worker-service:${IMAGE_TAG}
                        docker push ${DOCKERHUB_USERNAME}/result-service:${IMAGE_TAG}
                        docker push ${DOCKERHUB_USERNAME}/api-gateway:${IMAGE_TAG}

                        docker logout
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying services...'
                sh '''
                    docker compose -f docker-compose.prod.yml down || true

                    IMAGE_TAG=${IMAGE_TAG} \
                    DOCKERHUB_USERNAME=${DOCKERHUB_USERNAME} \
                    docker compose -f docker-compose.prod.yml up -d
                '''
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline completed successfully!'
        }
        failure {
            echo '❌ Pipeline failed!'
        }
        always {
            echo 'Pipeline finished.'
        }
    }
}