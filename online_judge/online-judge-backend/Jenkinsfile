pipeline {
    agent any

    environment {
        DOCKERHUB_USERNAME = 'sivasomanath2502'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Detect Changes') {
            steps {
                script {
                    def changedFiles = ''
                    try {
                        // Compare current commit to previous commit
                        changedFiles = sh(
                            script: "git diff --name-only HEAD~1 HEAD",
                            returnStdout: true
                        ).trim()
                    } catch (e) {
                        // First commit or shallow clone — build all
                        changedFiles = 'submission-service worker-service result-service api-gateway admin-service online-judge-frontend'
                        echo "Could not detect changes, building all"
                    }

                    echo "Changed files:\n${changedFiles}"

                    env.BUILD_SUBMISSION = changedFiles.contains('submission-service')      ? 'true' : 'false'
                    env.BUILD_WORKER     = changedFiles.contains('worker-service')          ? 'true' : 'false'
                    env.BUILD_RESULT     = changedFiles.contains('result-service')          ? 'true' : 'false'
                    env.BUILD_GATEWAY    = changedFiles.contains('api-gateway')             ? 'true' : 'false'
                    env.BUILD_ADMIN      = changedFiles.contains('admin-service')           ? 'true' : 'false'
                    env.BUILD_FRONTEND   = changedFiles.contains('online-judge-frontend')   ? 'true' : 'false'
                }
            }
        }

        stage('Trigger Service Pipelines') {
            steps {
                script {
                    parallel (

                        submission: {
                            if (env.BUILD_SUBMISSION == 'true') {
                                build job: 'submission-service', wait: true
                            }
                        },

                        worker: {
                            if (env.BUILD_WORKER == 'true') {
                                build job: 'worker-service', wait: true
                            }
                        },

                        result: {
                            if (env.BUILD_RESULT == 'true') {
                                build job: 'result-service', wait: true
                            }
                        },

                        gateway: {
                            if (env.BUILD_GATEWAY == 'true') {
                                build job: 'api-gateway', wait: true
                            }
                        },

                        admin: {
                            if (env.BUILD_ADMIN == 'true') {
                                build job: 'admin-service', wait: true
                            }
                        },

                        frontend: {
                            if (env.BUILD_FRONTEND == 'true') {
                                build job: 'online-judge-frontend', wait: true
                            }
                        }
                    )
                }
            }
        }

        stage('Deploy') {
            steps {
                dir('online_judge/online-judge-backend/ansible') {
                    sh """
                        ansible-playbook playbooks/deploy-app.yml \
                            -e "image_tag=latest" \
                            -e "dockerhub_username=${DOCKERHUB_USERNAME}"
                    """
                }
            }
        }
    }
    post {
        success {
            echo '✅ Root pipeline completed successfully!'
        }
        failure {
            echo '❌ Root pipeline failed!'
        }
        always {
            sh 'docker system prune -f --filter "until=2h" || true'
            echo 'Pipeline finished.'
        }
    }
}