pipeline {
    agent any

    tools {
        maven 'Maven 3'
        jdk 'JDK 17'
    }

    environment {
        DOCKERHUB_USERNAME = 'sivasomanath2502'
        SERVICE_NAME       = 'result-service'
        IMAGE_TAG          = "${BUILD_NUMBER}"
        ROOT_DIR           = 'online_judge/online-judge-backend'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                dir("${ROOT_DIR}") {
                    sh "mvn -B clean package -DskipTests -pl ${SERVICE_NAME} -am"
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir("${ROOT_DIR}/${SERVICE_NAME}") {
                    sh """
                        docker build \
                        -t ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG} \
                        -t ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:latest .
                    """
                }
            }
        }

        stage('Docker Push') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credential',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {

                    retry(3) {
                        sh """
                            echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
                            docker push ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG}
                        """
                    }

                    retry(3) {
                        sh """
                            echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
                            docker push ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:latest
                        """
                    }

                    sh "docker logout || true"
                }
            }
        }
    }

    post {
        success {
            echo "✅ ${SERVICE_NAME} deployed successfully — image tag: ${IMAGE_TAG}"
        }
        failure {
            echo "❌ ${SERVICE_NAME} pipeline failed!"
        }
        always {
            sh 'docker image prune -f || true'
        }
    }
}