pipeline {
    agent any

    environment {
        DOCKERHUB_USERNAME = 'sivasomanath2502'
        NAMESPACE          = 'wecode'
        ANSIBLE_DIR        = 'wecode/ansible'
    }

    stages {

        // ─────────────────────────────────────────────────────────────────
        // STAGE 1 — Checkout
        // ─────────────────────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 2 — Cluster state check
        //
        // This is the key stage that makes ALL three scenarios work:
        //
        //   NAMESPACE_EXISTS = false  → fresh cluster / deleted namespace
        //                               → force build ALL services
        //                               → apply full k8s stack
        //
        //   NAMESPACE_EXISTS = true   → cluster is running
        //                               → detect code changes
        //                               → build only what changed
        //                               → rollout only what changed
        //
        // ─────────────────────────────────────────────────────────────────
        stage('Cluster State Check') {
            steps {
                script {
                    def nsExists = sh(
                        script: "kubectl get namespace ${NAMESPACE} --no-headers --ignore-not-found 2>/dev/null | wc -l",
                        returnStdout: true
                    ).trim()

                    env.NAMESPACE_EXISTS   = (nsExists.toInteger() > 0) ? 'true' : 'false'
                    env.FULL_DEPLOY_NEEDED = (env.NAMESPACE_EXISTS == 'false') ? 'true' : 'false'

                    echo """
                    ============ Cluster State ============
                      Namespace '${NAMESPACE}' exists : ${env.NAMESPACE_EXISTS}
                      Full deploy needed               : ${env.FULL_DEPLOY_NEEDED}
                    =======================================""".stripIndent()
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 3 — Detect code changes (only when namespace exists)
        //
        // When FULL_DEPLOY_NEEDED = true we skip this stage entirely —
        // all BUILD_* flags are forced to true in the next stage.
        //
        // git diff HEAD~1 HEAD is the right tool for "what changed in this
        // push?" — but it must NEVER be the deciding factor for deploy.
        // ─────────────────────────────────────────────────────────────────
        stage('Detect Code Changes') {
            when {
                expression { env.FULL_DEPLOY_NEEDED == 'false' }
            }
            steps {
                script {
                    def changedFiles = ''
                    try {
                        changedFiles = sh(
                            script: "git diff --name-only HEAD~1 HEAD",
                            returnStdout: true
                        ).trim()
                    } catch (e) {
                        echo "git diff failed — assuming all services changed"
                        changedFiles = 'submission-service worker-service result-service api-gateway admin-service wecode-frontend'
                    }

                    echo "Changed files:\n${changedFiles ?: '(none)'}"

                    env.BUILD_SUBMISSION = changedFiles.contains('submission-service') ? 'true' : 'false'
                    env.BUILD_WORKER     = changedFiles.contains('worker-service')     ? 'true' : 'false'
                    env.BUILD_RESULT     = changedFiles.contains('result-service')     ? 'true' : 'false'
                    env.BUILD_GATEWAY    = changedFiles.contains('api-gateway')        ? 'true' : 'false'
                    env.BUILD_ADMIN      = changedFiles.contains('admin-service')      ? 'true' : 'false'
                    env.BUILD_FRONTEND   = changedFiles.contains('wecode-frontend')    ? 'true' : 'false'

                    // Track whether any service needs rebuilding (used by
                    // the deploy stage to decide rollout vs full apply)
                    def anyChanged = [
                        env.BUILD_SUBMISSION,
                        env.BUILD_WORKER,
                        env.BUILD_RESULT,
                        env.BUILD_GATEWAY,
                        env.BUILD_ADMIN,
                        env.BUILD_FRONTEND
                    ].any { it == 'true' }

                    env.ANY_SERVICE_CHANGED = anyChanged ? 'true' : 'false'

                    echo """
                    ============ Build Flags ============
                      submission-service : ${env.BUILD_SUBMISSION}
                      worker-service     : ${env.BUILD_WORKER}
                      result-service     : ${env.BUILD_RESULT}
                      api-gateway        : ${env.BUILD_GATEWAY}
                      admin-service      : ${env.BUILD_ADMIN}
                      wecode-frontend    : ${env.BUILD_FRONTEND}
                      Any changed        : ${env.ANY_SERVICE_CHANGED}
                    =====================================""".stripIndent()
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 4 — Force all flags when doing a fresh full deploy
        // ─────────────────────────────────────────────────────────────────
        stage('Set Full Deploy Flags') {
            when {
                expression { env.FULL_DEPLOY_NEEDED == 'true' }
            }
            steps {
                script {
                    env.BUILD_SUBMISSION    = 'true'
                    env.BUILD_WORKER        = 'true'
                    env.BUILD_RESULT        = 'true'
                    env.BUILD_GATEWAY       = 'true'
                    env.BUILD_ADMIN         = 'true'
                    env.BUILD_FRONTEND      = 'true'
                    env.ANY_SERVICE_CHANGED = 'true'
                    echo "Full deploy — all services will be built and deployed."
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 5 — Build changed services in parallel
        //
        // Each service has its own Jenkins job (one Jenkinsfile per service).
        // We trigger only the jobs whose flag is true.
        // If nothing changed AND namespace exists, this whole stage is skipped.
        // ─────────────────────────────────────────────────────────────────
        stage('Build Changed Services') {
            when {
                expression { env.ANY_SERVICE_CHANGED == 'true' }
            }
            steps {
                script {
                    def parallelJobs = [:]

                    if (env.BUILD_SUBMISSION == 'true') {
                        parallelJobs['submission-service'] = {
                            build job: 'submission-service',
                                  parameters: [string(name: 'DEPLOY_AFTER_BUILD', value: 'false')],
                                  wait: true, propagate: true
                        }
                    }
                    if (env.BUILD_WORKER == 'true') {
                        parallelJobs['worker-service'] = {
                            build job: 'worker-service',
                                  parameters: [string(name: 'DEPLOY_AFTER_BUILD', value: 'false')],
                                  wait: true, propagate: true
                        }
                    }
                    if (env.BUILD_RESULT == 'true') {
                        parallelJobs['result-service'] = {
                            build job: 'result-service',
                                  parameters: [string(name: 'DEPLOY_AFTER_BUILD', value: 'false')],
                                  wait: true, propagate: true
                        }
                    }
                    if (env.BUILD_GATEWAY == 'true') {
                        parallelJobs['api-gateway'] = {
                            build job: 'api-gateway',
                                  parameters: [string(name: 'DEPLOY_AFTER_BUILD', value: 'false')],
                                  wait: true, propagate: true
                        }
                    }
                    if (env.BUILD_ADMIN == 'true') {
                        parallelJobs['admin-service'] = {
                            build job: 'admin-service',
                                  parameters: [string(name: 'DEPLOY_AFTER_BUILD', value: 'false')],
                                  wait: true, propagate: true
                        }
                    }
                    if (env.BUILD_FRONTEND == 'true') {
                        parallelJobs['wecode-frontend'] = {
                            build job: 'wecode-frontend',
                                  parameters: [string(name: 'DEPLOY_AFTER_BUILD', value: 'false')],
                                  wait: true, propagate: true
                        }
                    }

                    parallel parallelJobs
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 6A — Full stack deploy (fresh cluster / deleted namespace)
        //
        // Applies the entire k8s directory: namespace, configmap, secrets,
        // infra (mysql/rabbitmq/redis), and all application services.
        // ─────────────────────────────────────────────────────────────────
        stage('Full Stack Deploy') {
            when {
                expression { env.FULL_DEPLOY_NEEDED == 'true' }
            }
            steps {
                dir("${ANSIBLE_DIR}") {
                    sh """
                        ansible-playbook playbooks/deploy-app-k8s.yml \
                            -e "image_tag=latest" \
                            -e "dockerhub_username=${DOCKERHUB_USERNAME}"
                    """
                }
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // STAGE 6B — Selective rollout (namespace exists, partial changes)
        //
        // When namespace already exists:
        //   - If services were rebuilt  → kubectl set image (rolling update)
        //   - If nothing rebuilt        → kubectl rollout restart (handles
        //                                 deleted pods / config changes)
        //
        // This always runs when FULL_DEPLOY_NEEDED is false, ensuring that
        // even a push with zero code changes re-syncs running pods.
        // ─────────────────────────────────────────────────────────────────
        stage('Selective Rollout') {
            when {
                expression { env.FULL_DEPLOY_NEEDED == 'false' }
            }
            steps {
                dir("${ANSIBLE_DIR}") {
                    sh """
                        ansible-playbook playbooks/selective-rollout-k8s.yml \
                            -e "image_tag=latest" \
                            -e "dockerhub_username=${DOCKERHUB_USERNAME}" \
                            -e "build_submission=${env.BUILD_SUBMISSION}" \
                            -e "build_worker=${env.BUILD_WORKER}" \
                            -e "build_result=${env.BUILD_RESULT}" \
                            -e "build_gateway=${env.BUILD_GATEWAY}" \
                            -e "build_admin=${env.BUILD_ADMIN}" \
                            -e "build_frontend=${env.BUILD_FRONTEND}"
                    """
                }
            }
        }

    }

    post {
        success { echo "Root pipeline completed — cluster is healthy." }
        failure { echo "Root pipeline FAILED — check the stage above." }
        always  { sh 'docker system prune -f --filter "until=2h" || true' }
    }
}