pipeline {
    agent any
    tools {
        maven 'Maven 3'
        jdk 'JDK 17'
    }
    environment {
        DOCKERHUB_USERNAME = 'sivasomanath2502'
        SERVICE_NAME       = 'worker-service'   // ← change per service
        IMAGE_TAG          = "${BUILD_NUMBER}"
        ROOT_DIR           = 'wecode/wecode-backend'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir("${ROOT_DIR}") {
                    sh "mvn -B clean package -DskipTests -pl ${SERVICE_NAME} -am"
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir("${ROOT_DIR}") {
                    sh "mvn test -pl ${SERVICE_NAME} || true"
                }
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: '**/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Docker Build & Push') {
            steps {
                dir("${ROOT_DIR}/${SERVICE_NAME}") {
                    withCredentials([usernamePassword(
                        credentialsId: 'docker-hub-credential',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        retry(3) {
                            sh """
                                docker build \
                                    -t ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG} \
                                    -t ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:latest .
                                echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
                                docker push ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG}
                                docker push ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:latest
                            """
                        }
                        sh "docker logout || true"
                    }
                }
            }
        }
        stage('Deploy to Kubernetes') {
            steps {
                dir('wecode/ansible/playbooks') {
                    sh """
                        ansible-playbook playbooks/deploy-service-k8s.yml \
                            -e "service_name=${SERVICE_NAME}" \
                            -e "image_tag=${IMAGE_TAG}" \
                            -e "dockerhub_username=${DOCKERHUB_USERNAME}"
                    """
                }
            }
        }
    }
    post {
        success { echo "✅ ${SERVICE_NAME}:${IMAGE_TAG} deployed to Kubernetes" }
        failure { echo "❌ ${SERVICE_NAME} pipeline failed" }
        always  { sh 'docker image prune -f || true' }
    }
}