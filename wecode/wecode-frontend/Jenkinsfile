pipeline {
    agent any
    parameters {
        string(name: 'DEPLOY_AFTER_BUILD', defaultValue: 'true',
               description: 'false when triggered by root pipeline')
    }

    environment {
        DOCKERHUB_USERNAME = 'sivasomanath2502'
        SERVICE_NAME       = 'wecode-frontend'
        FRONTEND_DIR       = 'wecode/wecode-frontend'
        NAMESPACE          = 'wecode'
        IMAGE_TAG          = "${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') { steps { checkout scm } }

        stage('Docker Build & Push') {
            steps {
                dir("${FRONTEND_DIR}") {
                    withCredentials([usernamePassword(
                        credentialsId: 'docker-hub-credential',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        retry(3) {
                            sh """
                                docker build \
                                    -t ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG} \
                                    -t ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:latest .
                                echo "\$DOCKER_PASS" | docker login -u "\$DOCKER_USER" --password-stdin
                                docker push ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:${IMAGE_TAG}
                                docker push ${DOCKERHUB_USERNAME}/${SERVICE_NAME}:latest
                            """
                        }
                        sh "docker logout || true"
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            when { expression { params.DEPLOY_AFTER_BUILD == 'true' } }
            steps {
                dir('wecode/ansible') {
                    sh """
                        ansible-playbook playbooks/deploy-service-k8s.yml \
                            -e "service_name=${SERVICE_NAME}" \
                            -e "image_tag=${IMAGE_TAG}" \
                            -e "dockerhub_username=${DOCKERHUB_USERNAME}"
                    """
                }
            }
        }
    }

    post {
        success { echo "✅ ${SERVICE_NAME}:${IMAGE_TAG} — ${params.DEPLOY_AFTER_BUILD == 'true' ? 'deployed' : 'built + pushed (root deploys)'}" }
        failure { echo "❌ ${SERVICE_NAME} pipeline failed" }
        always  { sh 'docker image prune -f || true' }
    }
}
